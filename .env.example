# TruthEngine AI - Production Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Groq AI
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# HuggingFace (free inference API for embeddings)
HF_API_TOKEN=your-huggingface-token
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# App Settings
DEBUG=false

# Cache TTL (seconds)
CACHE_DEFAULT_TTL=120

# Crawler
MAX_CONCURRENT_CRAWLS=3

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=https://your-frontend.vercel.app

# Keep-alive: Google Apps Script web app URL to prevent Render spin-down
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
